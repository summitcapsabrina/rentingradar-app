{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "functions", "node_modules", ".git", "*.bak"],
    "rewrites": [
      { "source": "/api/createCheckoutSession", "function": "createCheckoutSession" },
      { "source": "/api/createPortalSession", "function": "createPortalSession" },
      { "source": "/api/verifyCheckout", "function": "verifyCheckout" },
      { "source": "/api/syncSubscription", "function": "syncSubscription" },
      { "source": "/api/emailPreferences", "function": "emailPreferences" },
      { "source": "/api/unsubscribe", "function": "unsubscribe" },
      { "source": "/api/testEmail", "function": "testEmail" },
      { "source": "/api/sendMeetingInvite", "function": "sendMeetingInvite" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
