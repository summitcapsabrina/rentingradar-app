{
  "manifest_version": 3,
  "name": "RentingRadar",
  "version": "0.6.0",
  "description": "Paste a listing link (AirDNA, Zillow, Apartments.com, Hotpads, Facebook Marketplace, Craigslist) and RentingRadar auto-fills the property or competitor details in your CRM.",
  "author": "Summit Capital LLC",
  "homepage_url": "https://rentingradar.com",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "RentingRadar",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.airdna.co/*",
    "https://*.airbnb.com/*",
    "https://www.zillow.com/*",
    "https://www.apartments.com/*",
    "https://*.hotpads.com/*",
    "https://www.facebook.com/marketplace/*",
    "https://*.craigslist.org/*",
    "https://app.rentingradar.com/*",
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://app.rentingradar.com/*",
      "https://rentingradar.com/*"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://app.rentingradar.com/*"],
      "js": ["content/crm-bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
